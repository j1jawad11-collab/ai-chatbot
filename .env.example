# MongoDB - use a direct connection string (not +srv) for environments
# where DNS SRV lookups may be blocked
MONGO_URI=mongodb://DB_USER:DB_PASSWORD@host1:27017,host2:27017,host3:27017/chatbot?authSource=admin&retryWrites=true&w=majority&tls=true

# OpenRouter API key (https://openrouter.ai)
OPENAI_API_KEY=your_openrouter_key_here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
